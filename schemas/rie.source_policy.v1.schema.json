{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.rooted.dev/rie/rie.source_policy.v1.schema.json",
  "title": "rie.source_policy.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "policy_id",
    "version",
    "created_at_utc",
    "default_action",
    "audience_policy_id",
    "rules"
  ],
  "properties": {
    "schema": { "const": "rie.source_policy.v1" },
    "policy_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "created_at_utc": { "type": "string", "format": "date-time" },
    "label": { "type": "string" },
    "description": { "type": "string" },
    "default_action": {
      "type": "string",
      "enum": ["DENY", "QUARANTINE_REVIEW_ONLY", "ALLOW_WITH_EDUCATOR_WARNING", "ALLOW_CHILD_SAFE"]
    },
    "audience_policy_id": { "type": "string", "minLength": 1 },
    "domain_lists": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowlist": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "denylist": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "cautionlist": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "watchlist": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule_id", "priority", "when", "decision"],
        "properties": {
          "rule_id": { "type": "string", "minLength": 1 },
          "priority": { "type": "integer", "minimum": 1 },
          "label": { "type": "string" },
          "when": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "domain_list_membership": {
                "type": "string",
                "enum": ["allowlist", "denylist", "cautionlist", "watchlist"]
              },
              "content_kinds": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "video",
                    "textbook",
                    "paper",
                    "notes",
                    "dataset",
                    "protocol",
                    "course_page",
                    "syllabus"
                  ]
                }
              },
              "requires_provenance": { "type": "boolean" },
              "requires_institutional_or_publisher_anchor": { "type": "boolean" },
              "min_trust_signal_count": { "type": "integer", "minimum": 0 },
              "forbid_answer_like_patterns": { "type": "boolean" },
              "allow_community_sources": { "type": "boolean" },
              "allow_video_platforms": { "type": "boolean" },
              "max_domain_result_share": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          },
          "decision": {
            "type": "object",
            "additionalProperties": false,
            "required": ["action", "reason_code"],
            "properties": {
              "action": {
                "type": "string",
                "enum": ["DENY", "QUARANTINE_REVIEW_ONLY", "ALLOW_WITH_EDUCATOR_WARNING", "ALLOW_CHILD_SAFE", "DOWNRANK"]
              },
              "reason_code": { "type": "string", "minLength": 1 },
              "warning_label": { "type": "string" },
              "score_adjustment": { "type": "number" }
            }
          }
        }
      }
    }
  }
}
