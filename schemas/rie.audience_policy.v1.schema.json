{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.rooted.dev/rie/rie.audience_policy.v1.schema.json",
  "title": "rie.audience_policy.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "policy_id",
    "audience_band",
    "require_provenance",
    "require_institutional_or_publisher_anchor",
    "allow_community_sources",
    "allow_video_platforms",
    "allow_warning_labeled_results",
    "allow_quarantined_results",
    "deny_for_answer_like_patterns",
    "max_results_per_domain",
    "min_trust_signal_count"
  ],
  "properties": {
    "schema": { "const": "rie.audience_policy.v1" },
    "policy_id": { "type": "string", "minLength": 1 },
    "audience_band": {
      "type": "string",
      "enum": ["child_7_10", "child_11_13", "teen", "adult"]
    },
    "label": { "type": "string" },
    "require_provenance": { "type": "boolean" },
    "require_institutional_or_publisher_anchor": { "type": "boolean" },
    "allow_community_sources": { "type": "boolean" },
    "allow_video_platforms": { "type": "boolean" },
    "allow_warning_labeled_results": { "type": "boolean" },
    "allow_quarantined_results": { "type": "boolean" },
    "deny_for_answer_like_patterns": { "type": "boolean" },
    "max_results_per_domain": { "type": "integer", "minimum": 1 },
    "min_trust_signal_count": { "type": "integer", "minimum": 0 },
    "preferred_domain_classes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "institution",
          "publisher",
          "government",
          "museum_library_archive",
          "educational_video_platform"
        ]
      }
    },
    "notes": { "type": "string" }
  }
}
